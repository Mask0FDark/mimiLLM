{
  "vocab_size": 1024,
  "tokenizer": "bpe",
  "tokenizer_path": "tokenizer.json",
  "tie_word_embeddings": true,
  "context_length": 256,
  "d_model": 128,
  "n_layers": 6,
  "n_heads": 4,
  "d_mlp": 384,
  "batch_size": 4,
  "batches_per_epoch": null,
  "learning_rate": 0.0003,
  "weight_decay": 0.01,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_epsilon": 1e-8,
  "gradient_clip_norm": 1.0,
  "learning_rate_schedule": "cosine",
  "min_learning_rate_ratio": 0.1,
  "validation_interval": 250,
  "checkpoint_interval": 250,
  "save_validation_checkpoints": false,
  "early_stopping_patience": 6,
  "early_stopping_min_delta": 0.001,
  "qa_prompt_weight": 0.0,
  "qa_answer_prefix_weight": 1.0,
  "qa_answer_prefix_tokens": 0,
  "text_train_path": "../../data/text/train",
  "text_validation_path": "../../data/text/validation",
  "question_train_path": "../../data/question/train",
  "question_validation_path": "../../data/question/validation"
}
